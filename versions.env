# Current scripted baseline.
#
# These values are what the live build and packaging scripts use today. The
# previous 2.52.1 line is still available by override, but the default engine
# line is now 2.52.4. The CI/bootstrap path can seed from the local updated 5.1
# sysroot when the raw 5.1 SDK target archive itself is not public.

SFOS_SYSROOT_VERSION=5.1.0.5

LIBWPE_VERSION=1.17.0
LIBEPOXY_VERSION=1.5.11
WPEBACKEND_FDO_VERSION=1.17.0

LEGACY_WPEWEBKIT_VERSION=2.52.4
LEGACY_QT5_PLUGIN_SOURCE_VERSION=2.52.1

WPE_SFOS_COMPAT_VERSION=1.0.0
ATLANTIC_BROWSER_VERSION=1.0.0

# Engine migration target.
TARGET_SFOS_VERSION=5.1.0.5
TARGET_WPEWEBKIT_VERSION=2.52.4

# SFOS 5.1.0.5 compatibility defaults.
# The updated target root on this host provides newer glibc and GLib than the
# Ubuntu 24.04 build host, so the normal path no longer needs GLIBC retagging or
# the old glibc/GLib preload shims. Keep the remaining uncertain shims explicit
# so they can be re-checked independently as the runtime is exercised.
PATCH_GLIBC_VERSIONS=0
USE_GLIBC_COMPAT=1
USE_GLIB_COMPAT=0
USE_COW_STRING_COMPAT=0
USE_SIGILL_SKIP=1
USE_EGL_STUBS=1

# The WPE build now enables the bubblewrap sandbox again
# (ENABLE_BUBBLEWRAP_SANDBOX=ON in cmake/atlantic-wpe-features.cmake).  At
# runtime it stays OFF unless ATLANTIC_ENABLE_SANDBOX=1 (see
# deploy/runtime-common.sh).  bwrap and xdg-dbus-proxy are the device-side
# executables libWPEWebKit exec's when the sandbox is enabled; scripts/build-sandbox-deps.sh
# builds them and build-rpms-native.sh packages them as the bubblewrap /
# xdg-dbus-proxy RPMs (atlantic-browser Requires both).
BUBBLEWRAP_VERSION=0.11.0
XDG_DBUS_PROXY_VERSION=0.1.6

# Content-blocker (EasyList / EasyPrivacy) sources.
# These lists are NO LONGER vendored in git (they were 145k lines, ~85% of the
# repo, and went stale). build-rpms-native.sh fetches them at build time into
# data/content-blocker/ (gitignored), mirroring how bwrap/xdg-dbus-proxy are
# downloaded. easylist-to-webkit.py then compiles them into content-blocker.json.
#
# Reproducibility: EasyList publishes no dated URL for the combined files, so by
# default the latest snapshot is fetched. For locked builds, set the SHA256 pins
# below and CONTENT_BLOCKER_STRICT=1 (a self-hosted mirror is then recommended).
# Last snapshot that was vendored: Version 202605281837 (2026-05-28)
#   easylist.txt    sha256 350cf87cbdb3e35678ed1ddf236d0a32c7d8857b6a583c484b6476ca3c0c4442
#   easyprivacy.txt sha256 21458d0786025ced5cd03faad69bd6e0df320ef210b67814bb8e7c2f816c39a4
EASYLIST_URL=https://easylist.to/easylist/easylist.txt
EASYPRIVACY_URL=https://easylist.to/easylist/easyprivacy.txt
EASYLIST_SHA256=
EASYPRIVACY_SHA256=
CONTENT_BLOCKER_STRICT=0

# Adblock engine filter lists (Fanboy's Annoyance + uBO Annoyances)
FANBOY_ANNOYANCE_URL=https://secure.fanboy.co.nz/fanboy-annoyance.txt
UBO_ANNOYANCES_URL=https://raw.githubusercontent.com/uBlockOrigin/uAssets/master/filters/annoyances.txt
FANBOY_ANNOYANCE_SHA256=
UBO_ANNOYANCES_SHA256=

# Adblock engine filter lists (social widgets + anti-circumvention)
FANBOY_SOCIAL_URL=https://secure.fanboy.co.nz/fanboy-social.txt
ANTI_CV_URL=https://raw.githubusercontent.com/abp-filters/abp-filters-anti-cv/master/abp-filters-anti-cv.txt
FANBOY_SOCIAL_SHA256=
ANTI_CV_SHA256=

# Adblock engine filter lists (cookie / GDPR consent)
FANBOY_COOKIE_URL=https://secure.fanboy.co.nz/fanboy-cookiemonster.txt
FANBOY_COOKIE_SHA256=
