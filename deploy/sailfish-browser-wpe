#!/bin/sh
. "$(cd "$(dirname "$0")" && pwd)/runtime-common.sh"
# Terminate any existing browser instance to allow clean restart.
# Needed because SFOS/booster keeps apps alive after close, and the
# WPE sandbox child processes must be cleaned up.
OLD_PID=$(cat /tmp/sfos-browser-wpe.pid 2>/dev/null)
if [ -n "$OLD_PID" ] && [ -d "/proc/$OLD_PID" ]; then
    /bin/kill "$OLD_PID" 2>/dev/null
    i=0; while [ -d "/proc/$OLD_PID" ] && [ $i -lt 10 ]; do sleep 0.1; i=$((i+1)); done
    [ -d "/proc/$OLD_PID" ] && /bin/kill -9 "$OLD_PID" 2>/dev/null
fi
atlantic_cleanup_runtime_artifacts

ATLANTIC_LD_PRELOAD="${ATLANTIC_COMPAT_DIR}/libsigill_skip.so:${ATLANTIC_COMPAT_DIR}/libegl-stubs.so"
ATLANTIC_LD_LIBRARY_PATH="$(atlantic_default_library_path)"
atlantic_export_browser_env

echo $$ > /tmp/sfos-browser-wpe.pid
exec /usr/bin/sailfish-browser "$@"
