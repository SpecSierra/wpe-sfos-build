+// On drivers with unreliable cross-context synchronization (libhybris
+// Adreno), reusing a pooled texture lets a painting context write into a
+// texture the compositor may still have in-flight GPU reads on, flashing
+// stale/foreign content. With WEBKIT_BITMAP_TEXTURE_POOL_DISABLED=1 every
+// acquisition creates a fresh GL texture; the old one is deleted when
+// released and the driver defers actual deletion until pending reads finish.
+static bool texturePoolReuseDisabled()
+{
+    static bool disabled = [] {
+        const char* env = getenv("WEBKIT_BITMAP_TEXTURE_POOL_DISABLED");
+        return env && *env && strcmp(env, "0");
+    }();
+    return disabled;
+}
