--- a/Source/cmake/OptionsJSCOnly.cmake
+++ b/Source/cmake/OptionsJSCOnly.cmake
@@ -115,6 +115,29 @@
 endif ()
 
 find_package(ICU 70.1 REQUIRED COMPONENTS data i18n uc)
+if (ICU_FOUND)
+    foreach(_icu_component data i18n uc)
+        string(TOUPPER "${_icu_component}" _ICU_COMPONENT_UPPER)
+        set(_icu_library "${ICU_${_ICU_COMPONENT_UPPER}_LIBRARY}")
+        set(_icu_library_release "${ICU_${_ICU_COMPONENT_UPPER}_LIBRARY_RELEASE}")
+        if (TARGET ICU::${_icu_component})
+            if (_icu_library)
+                set_target_properties(ICU::${_icu_component} PROPERTIES
+                    IMPORTED_LOCATION "${_icu_library}"
+                    IMPORTED_LINK_INTERFACE_LANGUAGES "CXX"
+                )
+            endif ()
+            if (_icu_library_release)
+                set_property(TARGET ICU::${_icu_component} APPEND PROPERTY IMPORTED_CONFIGURATIONS RELEASE)
+                set_target_properties(ICU::${_icu_component} PROPERTIES
+                    IMPORTED_LOCATION_RELEASE "${_icu_library_release}"
+                    IMPORTED_LINK_INTERFACE_LANGUAGES_RELEASE "CXX"
+                )
+            endif ()
+        endif ()
+    endforeach ()
+endif ()
+
 if (APPLE)
     add_definitions(-DU_DISABLE_RENAMING=1)
 endif ()
