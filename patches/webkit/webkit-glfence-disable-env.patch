+// Some drivers (e.g. the libhybris-wrapped Adreno 610 on Sailfish OS)
+// advertise EGL/GL fence support but do not actually order GPU work across
+// shared contexts on a server wait, which corrupts Skia-GPU-painted tiles
+// when the compositor samples them. WPE_GL_FENCE_DISABLED=1 makes fences
+// unavailable so every call site falls back to its synchronous path
+// (GrSyncCpu::kYes / glFinish), which guarantees the producing context's
+// work is complete before any consumer sees the texture.
+static bool fencesDisabledByEnvironment()
+{
+    static bool disabled = [] {
+        const char* env = getenv("WPE_GL_FENCE_DISABLED");
+        return env && *env && strcmp(env, "0");
+    }();
+    return disabled;
+}
+
 static inline bool eglVersionSupportsFences(const GLDisplay& display)
 {
     return display.checkVersion(1, 5);
@@ -54,6 +73,9 @@
 
 bool GLFence::isSupported(const GLDisplay& display)
 {
+    if (fencesDisabledByEnvironment())
+        return false;
+
     auto* context = GLContextWrapper::currentContext();
