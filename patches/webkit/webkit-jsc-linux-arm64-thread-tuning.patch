--- a/Source/JavaScriptCore/runtime/Options.cpp
+++ b/Source/JavaScriptCore/runtime/Options.cpp
@@ -596,6 +596,23 @@
     Options::worklistFTLLoadWeight() = 20;
 #endif
 
+#if OS(LINUX) && CPU(ARM64)
+    // Linux ARM64 (e.g. Snapdragon 665 big.LITTLE 8-core) has no platform
+    // tuning block, so JSC defaults to 7 FTL compiler threads and 8 GC marker
+    // threads on an 8-core device — saturating the CPU during page load.
+    // Mirror the Darwin ARM64 conservative limits here.
+    Options::numberOfGCMarkers() = std::min<unsigned>(4, WTF::numberOfProcessorCores());
+    Options::minNumberOfWorklistThreads() = 1;
+    Options::maxNumberOfWorklistThreads() = std::min<unsigned>(3, WTF::numberOfProcessorCores());
+    Options::numberOfBaselineCompilerThreads() = std::min<unsigned>(2, WTF::numberOfProcessorCores());
+    Options::numberOfDFGCompilerThreads() = std::min<unsigned>(2, WTF::numberOfProcessorCores());
+    Options::numberOfFTLCompilerThreads() = std::min<unsigned>(2, WTF::numberOfProcessorCores());
+    Options::worklistLoadFactor() = 20;
+    Options::worklistBaselineLoadWeight() = 2;
+    Options::worklistDFGLoadWeight() = 5;
+    Options::worklistFTLLoadWeight() = 20;
+#endif
+
 #if OS(LINUX) && CPU(ARM)
     Options::maximumFunctionForCallInlineCandidateBytecodeCostForDFG() = 77;
     Options::maximumOptimizationCandidateBytecodeCost() = 42403;
