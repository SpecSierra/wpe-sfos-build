-static constexpr double decelFriction = 4;
+// Kinetic (fling) deceleration friction. Total coast distance = velocity/friction
+// and the fling time-constant = 1/friction, so a larger value makes the fling
+// shorter and more abrupt. Upstream hardcodes 4, which is tuned for desktop
+// trackpad/wheel kinetic and feels like "no momentum" for phone touch flicking
+// (a hard flick coasts barely half a screen then stops dead). Make it tunable
+// via WEBKIT_KINETIC_DECEL_FRICTION (range 0.3..8) so touch flinging can use a
+// lower friction (longer, smoother glide). See webkit-kinetic-decel-friction-env.patch.
+static double decelFrictionValue()
+{
+    static double value = [] {
+        if (const char* env = getenv("WEBKIT_KINETIC_DECEL_FRICTION")) {
+            double v = atof(env);
+            if (v >= 0.3 && v <= 8.0)
+                return v;
+        }
+        return 4.0;
+    }();
+    return value;
+}
 static constexpr double velocityAccumulationFloor = 0.33;
