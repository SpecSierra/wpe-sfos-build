TEMP env-gated diagnostic (WEBKIT_SCROLL_DIAG=1; revert before ship). Logs why a
kinetic fling truncates under main-thread jank: [START] = fling velocity +
estimated coast; [TICK] = per-frame elapsed/dt/velocity/offset-delta and which
end-condition (endVel = |velocity|<1, endDelta = per-tick move <1px) fires.
Applies on top of webkit-kinetic-decel-friction-env.patch. Diagnostic only.
--- a/Source/WebCore/platform/ScrollAnimationKinetic.cpp
+++ b/Source/WebCore/platform/ScrollAnimationKinetic.cpp
@@ -29,6 +29,7 @@
 
 #include "PlatformWheelEvent.h"
 #include "ScrollExtents.h"
+#include <cstdio>
 #include <cstdlib>
 #include <cstring>
 #include <wtf/TZoneMallocInlines.h>
@@ -91,6 +92,17 @@
 static constexpr double velocityAccumulationMax = 6.0;
 static constexpr Seconds scrollCaptureThreshold { 150_ms };
 
+// TEMP env-gated kinetic diagnostic (WEBKIT_SCROLL_DIAG=1). Off by default = one
+// cached bool check, no I/O. Confirms why a fling truncates under main-thread jank.
+static bool wpeScrollDiag()
+{
+    static bool on = [] {
+        const char* e = getenv("WEBKIT_SCROLL_DIAG");
+        return e && *e && strcmp(e, "0");
+    }();
+    return on;
+}
+
 namespace WebCore {
 
 WTF_MAKE_TZONE_ALLOCATED_IMPL(ScrollAnimationKinetic);
