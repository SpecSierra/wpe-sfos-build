     if (!m_frameUpdateRequested || !m_exportable)
         return;
 
+    // Throttle WPE to ~30fps by deferring frame_complete when the last dispatch
+    // was less than m_frameIntervalMs ago. RadioFrance (React, heavy rAF loops)
+    // needs ~26ms of JS per 16ms frame on the Snapdragon 665 -- causing constant
+    // overrun. At 24fps (41ms budget) JS fits within the frame, eliminating jank.
+    // When deferred, we post a delayed QQuickWindow::update() so the render
+    // thread re-checks after the remaining wait time.
+    const qint64 interval = m_frameIntervalMs;
+    if (interval > 0 && m_frameThrottleTimer.isValid()) {
+        const qint64 elapsed = m_frameThrottleTimer.elapsed();
+        if (elapsed < interval) {
+            if (m_view) {
+                if (QQuickWindow* w = m_view->window()) {
+                    const qint64 remaining = interval - elapsed;
+                    QTimer::singleShot(remaining, w, [w]() { w->update(); });
+                }
+            }
+            return;
+        }
+    }
+
     m_frameUpdateRequested = false;
+    if (!m_frameThrottleTimer.isValid())
+        m_frameThrottleTimer.start();
+    else
+        m_frameThrottleTimer.restart();
     wpe_view_backend_exportable_fdo_dispatch_frame_complete(m_exportable);
     if (m_committedImage)
         wpe_view_backend_exportable_fdo_egl_dispatch_release_exported_image(m_exportable, m_committedImage);
