# Current scripted baseline.
#
# These values are what the live build and packaging scripts use today.
# The engine migration target is tracked below so the repo can keep moving toward
# the new line without rediscovering every version pin.

SFOS_SYSROOT_VERSION=5.1.0.5

LIBWPE_VERSION=1.17.0
LIBEPOXY_VERSION=1.5.11
WPEBACKEND_FDO_VERSION=1.17.0

LEGACY_WPEWEBKIT_VERSION=2.52.1
LEGACY_QT5_PLUGIN_SOURCE_VERSION=2.50.5

WPE_SFOS_COMPAT_VERSION=1.0.0
ATLANTIC_BROWSER_VERSION=1.0.0

# Engine migration target.
TARGET_SFOS_VERSION=5.1.0.5
TARGET_WPEWEBKIT_VERSION=2.52.3

# Historical only: the old packaging path used to build and depend on bubblewrap
# even though the WPE build disables bubblewrap sandboxing. Keep the version pin
# here for reference, but do not wire it into the default package graph.
BUBBLEWRAP_VERSION=0.11.0
