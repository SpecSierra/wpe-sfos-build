+bool SkiaPaintingEngine::rasterOnCompositorThread()
+{
+    static std::once_flag onceFlag;
+    static bool enabled = false;
+
+    std::call_once(onceFlag, [] {
+        if (const char* envString = getenv("WEBKIT_RASTER_ON_COMPOSITOR_THREAD"))
+            enabled = envString[0] && strcmp(envString, "0");
+    });
+
+    return enabled;
+}
