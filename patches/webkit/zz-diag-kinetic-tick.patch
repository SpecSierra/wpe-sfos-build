+    if (wpeScrollDiag()) {
+        if (FILE* d = fopen("/tmp/wpe-scroll-diag.log", "a")) {
+            fprintf(d, "[TICK] t=%.3f dt=%.4f vel=%.1f offDelta=%.2f off=%.0f endVel=%d endDelta=%d\n",
