--- a/Source/WebKit/UIProcess/API/wpe/qt5/WPEQtViewBackend.cpp
+++ b/Source/WebKit/UIProcess/API/wpe/qt5/WPEQtViewBackend.cpp
@@ -24,6 +24,8 @@
 
 #include "WPEQtView.h"
 #include <QGuiApplication>
+#include <QMetaObject>
 #include <QOpenGLFunctions>
+#include <QQuickWindow>
 #include <QtGlobal>
 
@@ -212,8 +214,19 @@ void WPEQtViewBackend::displayImage(struct wpe_fdo_egl_exported_image* image)
 {
     Q_ASSUME(!m_lockedImage);
     m_lockedImage = image;
-    if (m_view)
-        m_view->triggerUpdate();
+    if (m_view) {
+        m_view->triggerUpdate();
+        // QQuickItem::update() from triggerUpdate() is not sufficient on hybris
+        // EGL: after eglSwapBuffers the QSGRenderThread stalls waiting for the
+        // main thread to call QQuickWindow::update() before it will process
+        // another frame. Without this, the first WPE frame renders correctly
+        // but subsequent frames are silently dropped until something else wakes
+        // the Qt render loop (e.g. a UI touch event). Posting
+        // QQuickWindow::update() here makes frame delivery demand-driven:
+        // the compositor only runs when WPE actually produces output.
+        if (QQuickWindow* w = m_view->window())
+            QMetaObject::invokeMethod(w, "update", Qt::QueuedConnection);
+    }
 }
 
