 namespace WebCore {
 
+// Tile prepaint tuning for scroll smoothness (see also
+// webkit-glfence-disable-env.patch / webkit-texpool-compositor-sync-env.patch):
+//  - WEBKIT_COVER_AREA_MULTIPLIER=<float 1..6>: how much area around the
+//    viewport gets prepainted (upstream hardcodes 2.0).
+//  - WEBKIT_DIRECTIONAL_TILE_COVERAGE=1: spend the cover budget mostly
+//    vertically and biased ahead of the current scroll direction, instead of
+//    inflating equally in all directions (horizontal prepaint is wasted on
+//    vertically-scrolling pages).
+static float coverAreaMultiplierFromEnvironment()
+{
+    static float multiplier = [] {
+        if (const char* env = getenv("WEBKIT_COVER_AREA_MULTIPLIER")) {
+            float value = atof(env);
+            if (value >= 1 && value <= 6)
+                return value;
+        }
+        return 2.0f;
+    }();
+    return multiplier;
+}
+
+static bool directionalCoverageEnabled()
+{
+    static bool enabled = [] {
+        const char* env = getenv("WEBKIT_DIRECTIONAL_TILE_COVERAGE");
+        return env && *env && strcmp(env, "0");
+    }();
+    return enabled;
+}
+
 WTF_MAKE_TZONE_ALLOCATED_IMPL(CoordinatedBackingStoreProxy);
 
 static uint32_t generateTileID()
