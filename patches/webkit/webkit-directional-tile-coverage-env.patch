+            coverRect.inflateX(m_visibleRect.width() * (m_coverAreaMultiplier - 1) / 2);
+            coverRect.inflateY(m_visibleRect.height() * (m_coverAreaMultiplier - 1) / 2);
+        }
         keepRect = coverRect;
